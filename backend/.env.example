# CORS settings (comma-separated). In production set to your Vercel domain.
CORS_ALLOWED_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false

# Optional auth toggle. Set true in production to enforce X-API-Key.
REQUIRE_API_KEY=false

# IP rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120

# Comma-separated API keys for X-API-Key header (used when REQUIRE_API_KEY=true)
ELYSIUM_API_KEYS=dev-key-123

# Estimation assumptions
KWH_PER_1K_TOKENS=0.0005
GRID_CO2_G_PER_KWH=400

# Optional: enable stronger compression if integrating an LLM compressor later
ENABLE_LLM_COMPRESSION=false
